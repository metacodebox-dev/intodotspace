{
  "name": "@space/backend",
  "version": "1.0.0",
  "description": "Space backend API server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc || exit 0",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clear-db": "ts-node --transpile-only src/scripts/clearDatabase.ts",
    "update-filled-orders": "ts-node --transpile-only src/scripts/updateFilledOrders.ts",
    "fix-order": "ts-node --transpile-only src/scripts/fixCorruptedOrder.ts",
    "test-liquidation": "ts-node --transpile-only src/scripts/testLiquidation.ts",
    "find-positions": "ts-node --transpile-only src/scripts/findUserPositions.ts",
    "backfill-positions": "ts-node --transpile-only src/scripts/backfillPositions.ts",
    "cleanup-positions": "ts-node --transpile-only src/scripts/cleanupClosedPositions.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.87.6",
    "@space/shared": "file:../shared",
    "@types/ioredis": "^5.0.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^5.1.1",
    "bs58": "^5.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "tweetnacl": "^1.0.3",
    "winston": "^3.11.0",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bs58": "^4.0.4",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
