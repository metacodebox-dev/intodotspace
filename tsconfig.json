{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./target",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["mocha", "chai", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "target/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "target"
  ]
}



